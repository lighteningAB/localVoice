<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#111111">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp">

        <ImageButton
            android:id="@+id/ime_mic_button"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_ime_mic_idle"
            android:src="@drawable/ic_localvoice_mic"
            android:scaleType="centerInside"
            android:padding="32dp"
            android:contentDescription="Toggle voice input" />

        <ProgressBar
            android:id="@+id/ime_spinner"
            style="?android:attr/progressBarStyle"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/localvoice_yellow"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/ime_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:text="Tap to dictate" />

    <ImageButton
        android:id="@+id/ime_switch_keyboard"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_more"
        android:contentDescription="Switch keyboard" />

</LinearLayout>
